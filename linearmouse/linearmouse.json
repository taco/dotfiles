{
  "$schema": "https://app.linearmouse.org/schema/0.10.0",
  "schemes": [
    {
      "if": {
        "device": {
          "category": "trackpad"
        }
      },
      "scrolling": {
        "reverse": {
          "vertical": false,
          "horizontal": false
        }
      }
    },
    {
      "if": {
        "device": {
          "category": "mouse"
        }
      },
      "scrolling": {
        "reverse": {
          "vertical": true,
          "horizontal": true
        }
      }
    }
  ]
}
