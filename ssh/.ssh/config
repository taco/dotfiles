# Alias for Windows native SSH
Host win
  HostName 192.168.x.x  # replace with your machine's local IP
  Port 22
  User DOMAIN\username  # replace with your Windows domain\username
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519

# Alias for WSL SSH
Host wsl
  HostName 192.168.x.x  # replace with your machine's local IP
  Port 2222
  User username  # replace with your WSL username
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
  LocalForward 8000 localhost:8000
  LocalForward 8189 localhost:8189
    
Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
